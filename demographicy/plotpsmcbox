## 定义函数：计算调和平均值
##    排除最近4个时间区间
calc_hmean_psmc <- function(dat, exclude_recent = 4, exclude_oldest = 0) {
  ## dat: 第1列为时间，第2列为 Ne
  
  ## 至少要有两列
  if (ncol(dat) < 2) {
    warning("数据少于2列，返回 NA")
    return(NA_real_)
  }
  
  ## 按时间从小到大排序：最近 -> 最古老
  dat <- dat[order(dat[, 1]), , drop = FALSE]
  
  ## 检查是否还有足够数据
  n <- nrow(dat)
  if (n <= (exclude_recent + exclude_oldest)) {
    warning("时间节点数不足，无法同时排除最近和最古老的时间节点，返回 NA")
    return(NA_real_)
  }
  
  ## 保留中间区间
  dat_use <- dat[(exclude_recent + 1):(n - exclude_oldest), , drop = FALSE]
  
  ## 去掉无效 Ne
  dat_use <- dat_use[is.finite(dat_use[, 2]) & dat_use[, 2] > 0, , drop = FALSE]
  
  if (nrow(dat_use) == 0) {
    warning("排除后没有有效 Ne，返回 NA")
    return(NA_real_)
  }
  
  ## 调和平均值
  hmean <- nrow(dat_use) / sum(1 / dat_use[, 2])
  return(hmean)
}

# 2. 定义函数：按物种批量计算并保存 csv
save_species_hmean <- function(prefix) {
  ## 抓取当前环境中该物种对象，例如 spoon1, spoon2, ...
  obj_names <- ls(pattern = paste0("^", prefix, "[0-9]+$"), envir = .GlobalEnv)
  
  if (length(obj_names) == 0) {
    warning(paste("没有找到对象：", prefix))
    return(NULL)
  }
  
  ## 按编号排序
  obj_num <- as.integer(sub(paste0("^", prefix), "", obj_names))
  obj_names <- obj_names[order(obj_num)]
  
  ## 逐个计算
  res <- data.frame(
    individual = obj_names,
    harmonic_mean_Ne = sapply(obj_names, function(x) {
      calc_hmean_psmc(get(x, envir = .GlobalEnv), exclude_recent = 4)
    }),
    stringsAsFactors = FALSE
  )
  
  ## 保存
  out_file <- paste0(prefix, "_harmonic_mean_Ne.csv")
  write.csv(res, out_file, row.names = FALSE)
  
  return(res)
}

## 依次计算每个物种
species_order <- c("spoon", "bar", "common", "eastern",
                   "great", "grey", "red", "ruddy", "terek")

result_list <- lapply(species_order, save_species_hmean)
