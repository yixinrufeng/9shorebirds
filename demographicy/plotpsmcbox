#画图
library(multcompView)

files <- paste0(species_order, "_harmonic_mean_Ne.csv")

plot_list <- list()
summary_df <- data.frame(
  species = species_order,
  mean = NA_real_,
  sd = NA_real_,
  n = NA_integer_,
  stringsAsFactors = FALSE
)

all_df <- data.frame(species = character(), value = numeric(), stringsAsFactors = FALSE)

for (i in seq_along(species_order)) {
  sp <- species_order[i]
  f <- files[i]
  
  dat <- read.csv(f, stringsAsFactors = FALSE)
  vals <- na.omit(dat$harmonic_mean_Ne)
  
  plot_list[[sp]] <- vals
  
  summary_df$mean[i] <- mean(vals)
  summary_df$sd[i]   <- sd(vals)
  summary_df$n[i]    <- length(vals)
  
  all_df <- rbind(
    all_df,
    data.frame(species = sp, value = vals, stringsAsFactors = FALSE)
  )
}

all_df$species <- factor(all_df$species, levels = species_order)

kw_res <- kruskal.test(value ~ species, data = all_df)
print(kw_res)

pw_res <- pairwise.wilcox.test(all_df$value, all_df$species,
                               p.adjust.method = "BH",
                               exact = FALSE)
print(pw_res)

p_mat <- pw_res$p.value
p_vec <- c()

for (i in seq_len(nrow(p_mat))) {
  for (j in seq_len(ncol(p_mat))) {
    if (!is.na(p_mat[i, j])) {
      nm <- paste(rownames(p_mat)[i], colnames(p_mat)[j], sep = "-")
      p_vec[nm] <- p_mat[i, j]
    }
  }
}

letters_res <- multcompLetters(p_vec, threshold = 0.05)$Letters
letters_res <- letters_res[species_order]

x_labs <- paste0(
  toupper(species_order),
